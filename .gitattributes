# Normalize line endings to LF — keeps Windows + POSIX in sync.

*.sh           text eol=lf
*.py           text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.txt          text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
