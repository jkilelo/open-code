# Normalize line endings to LF -- keeps Windows + POSIX in sync.
# Combined with the ASCII-only enforcement in tests/probe_ascii_only.py,
# this guarantees identical rendering on every platform.

* text=auto eol=lf

*.sh           text eol=lf
*.py           text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.txt          text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Windows-only artifacts keep their native line endings.
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf
